# Supabase project URL. Required when the persistence layer is connected.
SUPABASE_URL=
# Browser-safe Supabase anonymous/public key. Never place service_role here.
SUPABASE_ANON_KEY=
# Backend-only administrative key. Never expose it in frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI-compatible model endpoint. Optional while MockModelProvider is used.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Allowed local application origins.
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
