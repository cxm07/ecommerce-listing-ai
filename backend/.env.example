APP_ENV=development
APP_STORAGE_DIR=.local-data
# Supports one origin or comma-separated origins. Do not use * as a production default.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_BYTES=10485760
DEMO_ACTOR_ID=00000000-0000-0000-0000-000000000001
# Default remains memory. Postgres is for local development/CI only; never commit a real URL.
DATA_REPOSITORY=memory
SUPABASE_DB_URL=
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=5
# Server-only object storage configuration. Do not expose or commit a service role key.
FILE_STORAGE=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=task-files
